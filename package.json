{
  "name": "bible-editor",
  "private": true,
  "version": "0.0.1",
  "description": "Tactical 7-month replacement for gatewayEdit + tcCreate",
  "workspaces": [
    "api",
    "web"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:api": "npm --workspace api run dev",
    "dev:web": "npm --workspace web run dev",
    "build": "npm-run-all build:api build:web",
    "build:api": "npm --workspace api run build",
    "build:web": "npm --workspace web run build",
    "typecheck": "npm-run-all --parallel typecheck:api typecheck:web",
    "typecheck:api": "npm --workspace api run typecheck",
    "typecheck:web": "npm --workspace web run typecheck",
    "deploy": "npm-run-all build:web deploy:api",
    "deploy:api": "npm --workspace api run deploy"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "volta": {
    "node": "24.15.0",
    "npm": "11.12.1"
  }
}
