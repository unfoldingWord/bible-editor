{
  "name": "@bible-editor/api",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "deploy": "wrangler deploy --env production",
    "db:migrate:local": "wrangler d1 migrations apply bible_editor_dev --local",
    "db:migrate:remote": "wrangler d1 migrations apply bible_editor --remote --env production",
    "tail": "wrangler tail --env production"
  },
  "dependencies": {
    "hono": "^4.12.23",
    "jose": "^5.9.0",
    "usfm-js": "^3.4.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "typescript": "^5.5.0",
    "wrangler": "^4.90.0"
  }
}
