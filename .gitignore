# generated output from one-shot importers (scripts/import-*.mjs). The
# scripts themselves are tracked; their SQL output and downloaded tarballs
# are not.
scripts/out/
scripts/tmp/

# Playwright artifacts — HTML report, trace zips, screenshots from failures.
# Regenerated on every `npm run test:e2e` run.
playwright-report/
test-results/

# Local working files — present in the working tree but not part of the
# committed history. Listed here so `git status` stays clean across branch
# switches.
/AGENTS.md
/docs/ai-alignment-unicode-fix.md
scratch/

# USFM files anywhere — ad-hoc fetches for re-generating per-book SQL
# patches (e.g. the chapter-front verse-0 backfill) shouldn't show up in
# git status. The originally-seeded samples (ZEC/LAM/OBA + ISA-ust under
# docs/samples/) are already tracked and stay that way; gitignore only
# affects untracked files.
*.usfm
